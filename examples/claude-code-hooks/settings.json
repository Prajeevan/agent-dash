{
  "//": "Drop these hooks into your Claude Code settings.json (~/.claude/settings.json or .claude/settings.json).",
  "//1": "chmod +x notify.sh ask.sh, export AGENT_DASH_URL and AGENT_KEY, and fix the paths below.",
  "//2": "ask.sh needs jq. Stop uses timeout 600 so it can poll for your phone answer.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/agent-dash/examples/claude-code-hooks/notify.sh 'Session started' 0 update"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/agent-dash/examples/claude-code-hooks/notify.sh 'Claude needs your input' 2 update"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/agent-dash/examples/claude-code-hooks/ask.sh",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
