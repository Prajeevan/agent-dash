# Local dev secrets for `pnpm dev`. Copy to `.dev.vars` (gitignored) and fill in.
# In production these are set as Worker secrets by `pnpm setup` — not from this file.
# Generate a set locally with:  node -e 'import("./scripts/lib.mjs").then(m=>{const v=m.generateVapidKeys();console.log("AGENT_KEY="+m.randomKey(),"\nAPP_SECRET="+m.randomKey(),"\nVAPID_PUBLIC_KEY="+v.publicKey,"\nVAPID_PRIVATE_KEY="+v.privateKey)})'

AGENT_KEY=
APP_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
